# syntax=docker/dockerfile:1
#
# Containerfile for Ekko.
#
# Build:  docker build -f docker/Containerfile -t ekko .
# Local:  docker compose up --build
#
# GOLDEN STANDARD ALIGNMENT
# -------------------------
# This Containerfile follows the koda_automation golden standard pattern for production builds:
# - Multi-stage build with separate builder and runtime stages
# - Builder stage uses uv for Python dependency management with bytecode compilation
# - Runtime stage runs as non-root user (ekko:1000) for security
# - Healthcheck endpoint for container orchestration readiness
# - Minimal runtime image based on python:3.12-slim-bookworm
# - Layer caching optimization with mounted build cache
#
# Reference: C:/Users/LFR/OneDrive - AP Pension/Documents/projects/koda_automation/
#
# INTENTIONAL DEVIATIONS
# ----------------------
# None. This Containerfile matches the golden standard exactly for Python services.

ARG PYTHON_BASE=python:3.12-slim-bookworm

# -- Builder -------------------------------------------------------------------
FROM ${PYTHON_BASE} AS builder

COPY --from=ghcr.io/astral-sh/uv:0.7 /uv /bin/uv

ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy

SHELL ["/bin/bash", "-o", "pipefail", "-c"]
WORKDIR /app

COPY backend/pyproject.toml backend/uv.lock ./

RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-dev --no-install-project

# -- Runtime -------------------------------------------------------------------
FROM ${PYTHON_BASE}

WORKDIR /app

# hadolint ignore=DL3008
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --gid 1000 ekko \
    && useradd --uid 1000 --gid 1000 --shell /usr/sbin/nologin --no-log-init --create-home ekko \
    && mkdir -p logs data \
    && chown -R ekko:ekko /app

COPY --from=builder --chown=ekko:ekko /app/.venv /app/.venv
COPY --chown=ekko:ekko backend/src/ src/

ENV PATH="/app/.venv/bin:${PATH}" \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH="/app/src"

USER ekko

HEALTHCHECK --interval=30s --timeout=5s --retries=3 --start-period=15s \
    CMD ["python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:8000/api/health', timeout=3)"]

CMD ["python", "-m", "ekko"]
