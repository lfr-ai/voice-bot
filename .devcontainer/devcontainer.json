{
  "name": "voice-bot Dev Container",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11",
  "runArgs": [
    "--init"
  ],
  "workspaceFolder": "/workspace",
  "postCreateCommand": "pip install --upgrade pip && pip install uv pre-commit && uv sync --all-extras && uvx pre-commit install",
  "remoteUser": "vscode",
  "forwardPorts": [8000, 6500, 6600],
  "mounts": [
    "source=voice-uv-cache,target=/home/vscode/.cache/uv,type=volume",
    "source=voice-precommit-cache,target=/home/vscode/.cache/pre-commit,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml",
        "editorconfig.editorconfig",
        "DavidAnson.vscode-markdownlint",
        "streetsidesoftware.code-spell-checker",
        "github.copilot-chat"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "python.defaultInterpreterPath": "/workspace/.venv/bin/python",
        "python.terminal.activateEnvironment": false,
        "editor.formatOnSave": true,
        "files.trimTrailingWhitespace": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
          }
        }
      }
    }
  }
}
