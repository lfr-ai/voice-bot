# Example environment variables
HOST=127.0.0.1
PORT=8000
OPENAI_KEY=
OPENAI_ENDPOINT=
OPENAI_VERSION=
REDIS_URL=redis://127.0.0.1:6379/0
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres
# Example environment variables
HOST=127.0.0.1
PORT=8000
DATABASE_URL=postgresql://user:pass@localhost:5432/db
OPENAI_API_KEY=
LOGS_DIR_PATH=./logs
# Environment variables template for voice-bot
# Copy to .env and fill in secrets. Never commit real secrets.

# App
VOICE_HOST=127.0.0.1
VOICE_PORT=8000
VOICE_ENVIRONMENT=local
VOICE_LOG_LEVEL=INFO

# OpenAI / LLM
OPENAI_API_KEY=
OPENAI_ORGANIZATION=

# Optional Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=

# Telemetry
SENTRY_DSN=

# IPC / Streaming
AUDIO_STREAMER_HOST=127.0.0.1
AUDIO_STREAMER_PORT=5050

# Misc
ALLOW_ANONYMOUS=true
