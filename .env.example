# ─── Ekko Environment Configuration ───────────────────────────
# Copy this file to .env and fill in your values.
# All variables use the EKKO_ prefix for pydantic-settings.

# ── General ───────────────────────────────────────────────────
EKKO_ENVIRONMENT=local          # local | dev | test | staging | prod
EKKO_DEBUG=true
EKKO_HOST=127.0.0.1
EKKO_PORT=8000
EKKO_LOG_LEVEL=DEBUG

# ── LLM / OpenAI ─────────────────────────────────────────────
EKKO_LLM_PROVIDER=openai        # openai | azure_openai | anthropic
EKKO_LLM_DEFAULT_DEPLOYMENT=
EKKO_OPENAI_API_KEY=
EKKO_AZURE_OPENAI_ENDPOINT=
EKKO_AZURE_OPENAI_KEY=

# ── Auth / JWT ────────────────────────────────────────────────
EKKO_JWT_SECRET_KEY=change-me-ekko-jwt-secret
EKKO_JWT_EXPIRE_MINUTES=30

# ── PostgreSQL ────────────────────────────────────────────────
EKKO_POSTGRESQL_USER=postgres
EKKO_POSTGRESQL_PASSWORD=postgres
EKKO_POSTGRESQL_HOST=127.0.0.1
EKKO_POSTGRESQL_PORT=5432
EKKO_POSTGRESQL_NAME=ekko

# ── RAG ───────────────────────────────────────────────────────
EKKO_RAG_EMBEDDING_MODEL=text-embedding-3-small
EKKO_RAG_LLM_MODEL=gpt-4o

# ── Audio / STT ───────────────────────────────────────────────
EKKO_AUDIO_STREAMER_TCP_PORT=6600
EKKO_AUDIO_SAMPLE_RATE=48000
EKKO_AUDIO_CHANNELS=2
EKKO_STT_DEVICE=cpu
EKKO_STT_COMPUTE_TYPE=default

# ── CrewAI ────────────────────────────────────────────────────
EKKO_CREWAI_VERBOSE=false
EKKO_CREWAI_MAX_ITERATIONS=10

# ── PII Anonymization ────────────────────────────────────────
EKKO_PII_ENABLED=true
EKKO_PII_PATTERNS=cpr,phone,email,address
