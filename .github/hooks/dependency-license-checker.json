{
  "hooks": {
    "Stop": [
      {
        "type": "command",
        "command": ".github/hooks/scripts/check-licenses.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File .github\\hooks\\scripts\\check-licenses.ps1",
        "timeout": 60,
        "env": {
          "LICENSE_MODE": "warn",
          "LICENSE_LOG_DIR": "logs/copilot/license-checker"
        }
      }
    ]
  }
}
