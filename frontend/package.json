    "@storybook/react-vite": "^10.4.0",
    "@storybook/test": "^8.6.18",
    "@storybook/test-runner": "^0.24.4",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
