    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:storybook": "test-storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "shadcn": "shadcn",
    "ui:add": "shadcn add",
    "ui:diff": "shadcn diff"
  },
