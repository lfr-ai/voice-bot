{
  "threshold": 5,
  "reporters": ["console"],
  "ignore": [
    "**/__pycache__/**",
    "**/node_modules/**",
    "**/.venv/**",
    "**/dist/**",
    "**/build/**",
    "**/alembic/versions/**",
    "**/*.lock"
